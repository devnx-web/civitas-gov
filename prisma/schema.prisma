// Civitas Gov — schema do banco de dados (PostgreSQL via Prisma 7).
// Fase 0 do ROADMAP: fundação técnica. Modelagem multi-tenant.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Papel de acesso do usuário.
enum Role {
  admin
  gestor
  operador
}

/// Órgão/entidade cliente — unidade de isolamento multi-tenant.
model Tenant {
  id       String   @id @default(cuid())
  nome     String
  slug     String   @unique
  criadoEm DateTime @default(now())

  usuarios                   Usuario[]
  fornecedores               Fornecedor[]
  materiais                  Material[]
  almoxarifados              Almoxarifado[]
  bensPatrimoniais           BemPatrimonial[]
  estoques                   Estoque[]
  processosLicitatorios      ProcessoLicitatorio[]
  contratos                  Contrato[]
  configuracoes              Configuracao[]
  dotacoesOrcamentarias      DotacaoOrcamentaria[]
  empenhos                   Empenho[]
  titularesDados             TitularDados[]
  incidentesLGPD             IncidenteLGPD[]
  dpo                        DPO?
  planosReversao             PlanoReversao[]
  ticketsSuporte             TicketSuporte[]
  artigosBaseConhecimento    ArtigoBaseConhecimento[]
  configuracoesSLA           ConfiguracaoSLA[]
  centrosCusto               CentroCusto[]
  unidadesGestoras           UnidadeGestora[]
  setores                    Setor[]
  comissoes                  Comissao[]
  movimentacoesEstoque       MovimentacaoEstoque[]
  requisicoesMateriaisTenant RequisicaoMaterial[]
  termosGuarda               TermoGuardaResponsabilidade[]
  transferenciasPatrimoniais TransferenciaPatrimonial[]
  sancoesFornecedor          SancaoFornecedor[]
  pcas                       PCA[]
  solicitacoesCompra         SolicitacaoCompra[]
  pesquisasPreco             PesquisaPreco[]
  editais                    Edital[]
  atas                       Ata[]
  impugnacoes                Impugnacao[]
  recursos                   Recurso[]
  sessoesPregao              SessaoPregao[]
  garantias                  Garantia[]
  clausulasModelo            ClausulaModelo[]
  cronogramasFinanceiros     CronogramaFisicoFinanceiro[]
  restosPagar                RestoPagar[]
  convenios                  Convenio[]
  fiscalizacoesContrato      FiscalizacaoContrato[]
  ocorrenciasFiscalizacao    OcorrenciaFiscalizacao[]
  medicoes                   MedicaoContrato[]
  gruposMaterial             GrupoMaterial[]
  inventariosPatrimoniais    InventarioPatrimonial[]
  solicitacoesESIC           SolicitacaoESIC[]
  receitas                   Receita[]
  registrosTratamento        RegistroAtividadeTratamento[]
  agentesContratacao         AgenteContratacao[]
  logAcesso                  LogAcesso[]
  notificacoes               Notificacao[]
  preferenciasNotificacao    PreferenciaNotificacao[]

  @@map("tenants")
}

/// Usuário do sistema, vinculado a um tenant.
model Usuario {
  id           String   @id @default(cuid())
  tenantId     String
  nome         String
  email        String   @unique
  senhaHash    String
  role         Role     @default(operador)
  cargo        String
  setor        String
  ativo        Boolean  @default(true)
  totpSecret   String?
  totpAtivado  Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissoes UsuarioPermissao[]
  tokensRecuperacao TokenRecuperacaoSenha[]

  @@index([tenantId])
  @@map("usuarios")
}

/// Token de recuperação de senha — gerado ao solicitar o reset.
model TokenRecuperacaoSenha {
  id        String    @id @default(cuid())
  usuarioId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  criadoEm  DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([usuarioId])
  @@map("tokens_recuperacao_senha")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

/// Tipo de operação registrada na trilha de auditoria.
enum AcaoAuditoria {
  CRIAR
  ATUALIZAR
  EXCLUIR
}

/// Registro imutável de operação auditável — trilha completa com before/after.
/// Fase 11 (B4): colunas `prevHash`/`currentHash` formam a cadeia SHA-256
/// imutável (REQ-NF-016). Ambas são nullable na fundação — a constraint
/// `@unique` em `currentHash` só entra após o backfill (plano 11-04).
model Auditoria {
  id          String        @id @default(cuid())
  tenantId    String
  usuarioId   String?
  acao        AcaoAuditoria
  entidade    String
  entidadeId  String
  antes       Json?
  depois      Json?
  ip          String?
  userAgent   String?
  prevHash    String?
  currentHash String?
  criadoEm    DateTime      @default(now())

  @@index([tenantId, criadoEm(sort: Desc)])
  @@index([tenantId, entidade, entidadeId])
  @@map("auditorias")
}

// ─── RBAC granular ────────────────────────────────────────────────────────────

/// Módulo/área do sistema ao qual a permissão se aplica.
/// Fase 11: os 8 valores finais (notificacoes..ia) são adicionados na
/// migração `v05_fundacao` via `ALTER TYPE ... ADD VALUE` consolidado
/// (única operação possível fora de transação no Postgres). Apenas
/// `notificacoes` e `jobs` serão usados em RBAC nesta fase; os outros
/// 6 ficam declarados aguardando Fases 12+/15+ (decisão B4 do plano).
enum Escopo {
  licitacoes
  contratos
  fornecedores
  almoxarifado
  patrimonio
  transparencia
  configuracoes
  usuarios
  auditoria
  relatorios
  orcamento
  financeiro
  notificacoes
  jobs
  helpdesk
  tce_es
  webhooks
  api
  bi
  ia
}

/// Operação controlada pela permissão.
enum Operacao {
  visualizar
  criar
  editar
  excluir
  aprovar
  exportar
}

/// Catálogo de permissões disponíveis no sistema (escopo × operação).
model Permissao {
  id        String   @id @default(cuid())
  escopo    Escopo
  operacao  Operacao
  descricao String

  rolePermissoes    RolePermissao[]
  usuarioPermissoes UsuarioPermissao[]

  @@unique([escopo, operacao])
  @@map("permissoes")
}

/// Permissões padrão atribuídas a cada papel (Role). Base do RBAC.
model RolePermissao {
  id          String @id @default(cuid())
  role        Role
  permissaoId String

  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@unique([role, permissaoId])
  @@map("role_permissoes")
}

/// Override de permissão por usuário. Prevalece sobre RolePermissao.
/// concedido=true → garante acesso mesmo que o role não tenha.
/// concedido=false → bloqueia acesso mesmo que o role tenha.
model UsuarioPermissao {
  id          String   @id @default(cuid())
  tenantId    String
  usuarioId   String
  permissaoId String
  concedido   Boolean
  criadoEm    DateTime @default(now())

  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usuarioId, permissaoId])
  @@map("usuario_permissoes")
}

enum StatusAssinatura {
  pendente
  assinada
  cancelada
  expirada
}

enum TipoAssinatura {
  eletronica
  digital_icp
}

enum SituacaoBem {
  disponivel
  baixado
  emprestado
  cedido
  locado
  em_manutencao
  desuso
  inservivel
  transferido
  ativo
}

model DocumentoAssinavel {
  id           String           @id @default(cuid())
  tenantId     String
  titulo       String
  descricao    String?
  tipo         String
  entidade     String
  entidadeId   String
  arquivoUrl   String
  hashSha256   String?
  status       StatusAssinatura @default(pendente)
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  assinaturas Assinatura[]

  @@index([tenantId])
  @@index([entidade, entidadeId])
  @@map("documentos_assinaveis")
}

model Assinatura {
  id                String         @id @default(cuid())
  tenantId          String
  documentoId       String
  signatarioId      String
  tipo              TipoAssinatura
  nomeSignatario    String
  cargoSignatario   String?
  cpfSignatario     String?
  dataAssinatura    DateTime       @default(now())
  codigoVerificacao String         @unique
  ipOrigem          String?
  userAgent         String?
  certificadoInfo   Json?
  valida            Boolean        @default(true)
  criadoEm          DateTime       @default(now())

  documento DocumentoAssinavel @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([documentoId])
  @@map("assinaturas")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODELOS ADICIONAIS PARA IMPORTAÇÃO/EXPORTAÇÃO EXCEL
// ═══════════════════════════════════════════════════════════════════════════════

enum TipoMaterial {
  consumo
  permanente
  servico
  obra
}

enum CategoriaMaterial {
  perecivel
  nao_perecivel
  estocavel
  combustivel
}

model UnidadeMedida {
  id        String     @id @default(cuid())
  tenantId  String
  codigo    String
  nome      String
  ativo     Boolean    @default(true)
  criadoEm  DateTime   @default(now())
  materiais Material[]

  @@index([tenantId])
  @@map("unidades_medida")
}

model Material {
  id                 String                   @id @default(cuid())
  tenantId           String
  codigo             String                   @unique
  descricao          String
  descricaoCompleta  String?
  tipo               TipoMaterial
  categoria          CategoriaMaterial?
  unidadeMedidaId    String
  subclasseId        String?
  catmat             String?
  catser             String?
  imagemUrl          String?
  ativo              Boolean                  @default(true)
  criadoEm           DateTime                 @default(now())
  atualizadoEm       DateTime                 @updatedAt
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unidadeMedida      UnidadeMedida            @relation(fields: [unidadeMedidaId], references: [id])
  subclasse          SubclasseMaterial?       @relation(fields: [subclasseId], references: [id], onDelete: SetNull)
  estoques           Estoque[]
  movimentacoes      MovimentacaoEstoque[]
  itensRequisicao    ItemRequisicaoMaterial[]
  // Fase 4
  itensPCA           ItemPCA[]
  itensSolicitacao   ItemSolicitacaoCompra[]
  itensPesquisaPreco ItemPesquisaPreco[]
  itensAtaRP         ItemAtaRegistroPreco[]

  @@index([tenantId])
  @@index([tenantId, ativo])
  @@map("materiais")
}

enum TipoFornecedor {
  pf
  pj
}

model Fornecedor {
  id           String                  @id @default(cuid())
  tenantId     String
  tipo         TipoFornecedor
  nome         String
  nomeFantasia String?
  cpfCnpj      String
  ie           String?
  im           String?
  crc          String?
  email        String?
  telefone     String?
  endereco     String?
  cidade       String?
  uf           String?                 @db.VarChar(2)
  cep          String?
  banco        String?
  agencia      String?
  conta        String?
  ativo        Boolean                 @default(true)
  criadoEm     DateTime                @default(now())
  atualizadoEm DateTime                @updatedAt
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentos   FornecedorDocumento[]
  contratos    Contrato[]
  empenhos     Empenho[]
  sancoes      SancaoFornecedor[]
  // Fase 4
  cotacoes     Cotacao[]
  lances       Lance[]
  habilitacoes HabilitacaoFornecedor[]
  recursos     Recurso[]
  itensAtaRP   ItemAtaRegistroPreco[]

  @@index([tenantId])
  @@index([tenantId, ativo])
  @@map("fornecedores")
}

model FornecedorDocumento {
  id           String     @id @default(cuid())
  fornecedorId String
  tipo         String
  numero       String?
  validade     DateTime?
  arquivoUrl   String?
  status       String     @default("valido")
  criadoEm     DateTime   @default(now())
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  @@index([fornecedorId])
  @@map("fornecedor_documentos")
}

model Almoxarifado {
  id                               String                @id @default(cuid())
  tenantId                         String
  codigo                           String
  nome                             String
  setor                            String?
  local                            String?
  ativo                            Boolean               @default(true)
  criadoEm                         DateTime              @default(now())
  tenant                           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  estoques                         Estoque[]
  movimentacoes                    MovimentacaoEstoque[]
  requisicoesMateriaisAlmoxarifado RequisicaoMaterial[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@map("almoxarifados")
}

model Estoque {
  id             String       @id @default(cuid())
  tenantId       String
  almoxarifadoId String
  materialId     String
  quantidade     Decimal      @default(0) @db.Decimal(18, 4)
  precoMedio     Decimal      @default(0) @db.Decimal(18, 4)
  estoqueMinimo  Decimal      @default(0) @db.Decimal(18, 4)
  estoqueMaximo  Decimal      @default(0) @db.Decimal(18, 4)
  pontoReposicao Decimal      @default(0) @db.Decimal(18, 4)
  localizacao    String?
  bloqueado      Boolean      @default(false)
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  almoxarifado   Almoxarifado @relation(fields: [almoxarifadoId], references: [id])
  material       Material     @relation(fields: [materialId], references: [id])
  lotes          LoteEstoque[]

  @@unique([almoxarifadoId, materialId])
  @@index([tenantId])
  @@map("estoques")
}

model LoteEstoque {
  id              String    @id @default(cuid())
  estoqueId       String
  numero          String
  fabricante      String?
  dataFabricacao  DateTime?
  dataValidade    DateTime?
  quantidadeAtual Decimal   @db.Decimal(18, 4)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  estoque         Estoque   @relation(fields: [estoqueId], references: [id], onDelete: Cascade)

  @@index([estoqueId, dataValidade])
  @@map("lotes_estoque")
}

enum TipoBem {
  movel
  imovel
  intangivel
  semovente
}

enum EstadoConservacao {
  otimo
  bom
  regular
  ruim
  pessimo
  inservivel
}

model BemPatrimonial {
  id                         String                     @id @default(cuid())
  tenantId                   String
  numeroTombamento           String                     @unique
  tipo                       TipoBem
  descricao                  String
  marca                      String?
  modelo                     String?
  numeroSerie                String?
  cor                        String?
  imagemUrl                  String?
  valorAquisicao             Decimal                    @db.Decimal(18, 4)
  dataAquisicao              DateTime
  valorResidual              Decimal?                   @db.Decimal(18, 4)
  percentualDepreciacaoAnual Decimal?                   @db.Decimal(5, 2)
  contaContabilId            String?
  fornecedorId               String?
  empenho                    String?
  situacao                   SituacaoBem                @default(ativo)
  estadoConservacao          EstadoConservacao?
  localizacaoAtual           String?
  responsavelId              String?
  observacoes                String?
  ativo                      Boolean                    @default(true)
  criadoEm                   DateTime                   @default(now())
  atualizadoEm               DateTime                   @updatedAt
  tenant           Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  termos           BemTermo[]
  transferencias   TransferenciaPatrimonial[]
  itensInventario  ItemInventario[]

  @@index([tenantId])
  @@index([tenantId, situacao])
  @@index([tenantId, tipo])
  @@map("bens_patrimoniais")
}

model Configuracao {
  id           String   @id @default(cuid())
  tenantId     String
  chave        String
  valor        String
  tipo         String   @default("texto") // texto, json, numero, booleano
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, chave])
  @@index([tenantId])
  @@map("configuracoes")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4 — LICITAÇÕES & CONTRATOS (modelos persistentes)
// ═══════════════════════════════════════════════════════════════════════════════

enum ModalidadeLicitacao {
  pregao_eletronico
  pregao_presencial
  concorrencia
  tomada_preco
  convite
  concurso
  leilao
  dispensa
  inexigibilidade
}

enum StatusProcesso {
  planejamento
  publicado
  em_disputa
  homologado
  deserta
  fracassada
  revogada
  anulada
}

enum StatusContrato {
  vigente
  encerrado
  a_vencer
  rescindido
}

enum TipoAditamento {
  prorrogacao
  reajuste
  acréscimo
  supressao
  alteracao
}

model ProcessoLicitatorio {
  id              String              @id @default(cuid())
  tenantId        String
  numero          String
  ano             Int
  modalidade      ModalidadeLicitacao
  objeto          String
  valorEstimado   Decimal             @db.Decimal(18, 4)
  dataAbertura    DateTime?
  dataHomologacao DateTime?
  status          StatusProcesso      @default(planejamento)
  srp             Boolean             @default(false) // Registro de Preço
  cnpjOrgao       String? // CNPJ do órgão para PNCP
  unidadeCodigo   String? // Código unidade administrativa PNCP
  observacoes     String?
  criadoEm        DateTime            @default(now())
  atualizadoEm    DateTime            @updatedAt

  itens              ItemLicitacao[]
  contratos          Contrato[]
  publicacoes        PublicacaoPNCP[]
  empenhos           Empenho[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Fase 4
  editais            Edital[]
  atas               Ata[]
  impugnacoes        Impugnacao[]
  recursos           Recurso[]
  sessoesPregao      SessaoPregao[]
  pesquisasPreco     PesquisaPreco[]
  solicitacoesCompra SolicitacaoCompra[]
  convenios          Convenio[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("processos_licitatorios")
}

model ItemLicitacao {
  id                    String   @id @default(cuid())
  tenantId              String
  processoId            String
  numeroItem            Int
  descricao             String
  quantidade            Decimal  @db.Decimal(18, 4)
  valorUnitarioEstimado Decimal  @db.Decimal(18, 4)
  valorTotalEstimado    Decimal  @db.Decimal(18, 4)
  unidadeMedida         String?
  categoria             Int? // 1=Material, 2=Serviço, 3=Obra (PNCP)
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  processo ProcessoLicitatorio @relation(fields: [processoId], references: [id], onDelete: Cascade)
  // Fase 4
  lances   Lance[]

  @@index([tenantId, processoId])
  @@map("itens_licitacao")
}

model Contrato {
  id                 String         @id @default(cuid())
  tenantId           String
  numero             String
  ano                Int
  processoId         String?
  fornecedorId       String
  objeto             String
  valorOriginal      Decimal        @db.Decimal(18, 4)
  valorAtual         Decimal        @db.Decimal(18, 4)
  dataAssinatura     DateTime
  dataInicioVigencia DateTime
  dataFimVigencia    DateTime
  status             StatusContrato @default(vigente)
  observacoes        String?
  criadoEm           DateTime       @default(now())
  atualizadoEm       DateTime       @updatedAt

  processo                ProcessoLicitatorio?         @relation(fields: [processoId], references: [id], onDelete: SetNull)
  fornecedor              Fornecedor                   @relation(fields: [fornecedorId], references: [id])
  tenant                  Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aditamentos             Aditamento[]
  empenhos                Empenho[]
  publicacoes             PublicacaoPNCP[]
  planosReversao          PlanoReversao[]
  // Fase 4
  garantias               Garantia[]
  cronograma              CronogramaFisicoFinanceiro[]
  fiscalizacoes           FiscalizacaoContrato[]
  ocorrenciasFiscalizacao OcorrenciaFiscalizacao[]
  medicoes                MedicaoContrato[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("contratos")
}

model Aditamento {
  id             String         @id @default(cuid())
  tenantId       String
  contratoId     String
  numero         String
  tipo           TipoAditamento
  descricao      String?
  valorAcrescimo Decimal?       @db.Decimal(18, 4)
  valorSupressao Decimal?       @db.Decimal(18, 4)
  novaDataFim    DateTime?
  dataAssinatura DateTime?
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([tenantId, contratoId])
  @@map("aditamentos")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 7 — INTEGRAÇÃO PNCP (Portal Nacional de Contratações Públicas)
// ═══════════════════════════════════════════════════════════════════════════════

enum TipoPublicacaoPNCP {
  contratacao
  contrato
  termo
}

enum StatusPublicacaoPNCP {
  rascunho
  enviado
  publicado
  erro
  retificado
}

model PublicacaoPNCP {
  id                 String               @id @default(cuid())
  tenantId           String
  tipo               TipoPublicacaoPNCP
  entidade           String // nome da entidade local (ProcessoLicitatorio, Contrato, Aditamento)
  entidadeId         String // ID local
  numeroControlePNCP String? // número de controle retornado pelo PNCP
  status             StatusPublicacaoPNCP @default(rascunho)
  payloadEnviado     Json? // JSON enviado ao PNCP
  respostaPNCP       Json? // resposta da API PNCP
  erroMensagem       String?
  enviadoEm          DateTime?
  retificadoEm       DateTime?
  criadoEm           DateTime             @default(now())
  atualizadoEm       DateTime             @updatedAt

  processo   ProcessoLicitatorio? @relation(fields: [processoId], references: [id], onDelete: SetNull)
  processoId String?
  contrato   Contrato?            @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  contratoId String?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([entidade, entidadeId])
  @@map("publicacoes_pncp")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 6 — SIAFIC / EXECUÇÃO ORÇAMENTÁRIA
// ═══════════════════════════════════════════════════════════════════════════════

model DotacaoOrcamentaria {
  id                  String   @id @default(cuid())
  tenantId            String
  ano                 Int
  unidadeOrcamentaria String // UO (código)
  funcao              String
  subfuncao           String
  programa            String
  acao                String
  subtitulo           String?
  naturezaDespesa     String // 6 dígitos (3.3.90.00)
  fonteRecurso        String
  valorInicial        Decimal  @db.Decimal(18, 4)
  valorAtual          Decimal  @db.Decimal(18, 4)
  valorBloqueado      Decimal  @default(0) @db.Decimal(18, 4)
  valorEmpenhado      Decimal  @default(0) @db.Decimal(18, 4)
  valorLiquidado      Decimal  @default(0) @db.Decimal(18, 4)
  valorPago           Decimal  @default(0) @db.Decimal(18, 4)
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  empenhos Empenho[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ano, unidadeOrcamentaria, funcao, subfuncao, programa, acao, naturezaDespesa, fonteRecurso])
  @@index([tenantId])
  @@index([tenantId, ano])
  @@map("dotacoes_orcamentarias")
}

enum TipoEmpenhoSIAFIC {
  ordinario
  estimativo
  global
  avulso
}

enum StatusEmpenho {
  ativo
  anulado
  estornado
  liquidado
  pago
}

model Empenho {
  id             String            @id @default(cuid())
  tenantId       String
  numero         String
  ano            Int
  dotacaoId      String?
  contratoId     String?
  processoId     String?
  fornecedorId   String?
  valor          Decimal           @db.Decimal(18, 4)
  valorAnulado   Decimal           @default(0) @db.Decimal(18, 4)
  valorLiquidado Decimal           @default(0) @db.Decimal(18, 4)
  valorPago      Decimal           @default(0) @db.Decimal(18, 4)
  dataEmpenho    DateTime
  tipo           TipoEmpenhoSIAFIC @default(ordinario)
  status         StatusEmpenho     @default(ativo)
  observacao     String?
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  contrato      Contrato?             @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  dotacao       DotacaoOrcamentaria?  @relation(fields: [dotacaoId], references: [id], onDelete: SetNull)
  fornecedor    Fornecedor?           @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  processo      ProcessoLicitatorio?  @relation(fields: [processoId], references: [id], onDelete: SetNull)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liquidacoes   Liquidacao[]
  pagamentos    Pagamento[]
  movimentacoes MovimentacaoEstoque[]
  // Fase 4
  restoPagar    RestoPagar?

  @@index([tenantId, dotacaoId])
  @@index([tenantId, contratoId])
  @@index([tenantId, status])
  @@map("empenhos")
}

enum StatusLiquidacao {
  ativa
  estornada
}

model Liquidacao {
  id              String           @id @default(cuid())
  tenantId        String
  empenhoId       String
  numero          String
  valor           Decimal          @db.Decimal(18, 4)
  dataLiquidacao  DateTime
  status          StatusLiquidacao @default(ativa)
  documentoFiscal String? // NF, nota de despesa etc
  observacao      String?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  empenho    Empenho     @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  pagamentos Pagamento[]

  @@index([tenantId, empenhoId])
  @@map("liquidacoes")
}

enum StatusPagamento {
  programado
  efetivado
  estornado
}

model Pagamento {
  id             String          @id @default(cuid())
  tenantId       String
  empenhoId      String
  liquidacaoId   String?
  numero         String
  valor          Decimal         @db.Decimal(18, 4)
  dataPagamento  DateTime
  status         StatusPagamento @default(programado)
  formaPagamento String? // TED, boleto, etc
  observacao     String?
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt

  empenho    Empenho     @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  liquidacao Liquidacao? @relation(fields: [liquidacaoId], references: [id], onDelete: SetNull)

  @@index([tenantId, empenhoId])
  @@index([tenantId, status])
  @@map("pagamentos")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 9 — TCE-ES / LGPD / REVERSIBILIDADE / HELP DESK
// ═══════════════════════════════════════════════════════════════════════════════

// ── LGPD ─────────────────────────────────────────────────────────────────────

enum TipoAcaoLGPD {
  coleta
  armazenamento
  processamento
  compartilhamento
  exclusao
  anonimizacao
}

enum BaseLegalLGPD {
  consentimento
  cumprimento_obrigacao_legal
  execucao_politicas_publicas
  pesquisa
  exercicio_direitos
  legítimo_interesse
  protecao_vida
  tutela_saude
  contrato
}

enum CategoriasDadosTratados {
  dados_comuns
  dados_sensiveis
  dados_criancas
}

model TitularDados {
  id           String   @id @default(cuid())
  tenantId     String
  nome         String
  email        String?
  cpf          String?
  telefone     String?
  endereco     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  consentimentos ConsentimentoLGPD[]
  registros      RegistroProcessamentoDados[]
  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, cpf])
  @@map("titulares_dados")
}

model ConsentimentoLGPD {
  id                 String        @id @default(cuid())
  tenantId           String
  titularId          String
  finalidade         String
  dadosTratados      String // descrição dos dados
  baseLegal          BaseLegalLGPD
  concedido          Boolean       @default(true)
  dataConsentimento  DateTime      @default(now())
  dataRevogacao      DateTime?
  canalConsentimento String? // web, presencial, telefone
  ipOrigem           String?
  userAgent          String?
  criadoEm           DateTime      @default(now())

  titular TitularDados @relation(fields: [titularId], references: [id], onDelete: Cascade)

  @@index([tenantId, titularId])
  @@map("consentimentos_lgpd")
}

/// RoPA — Registro de Atividades de Tratamento (Art. 37 LGPD).
model RegistroAtividadeTratamento {
  id                           String                    @id @default(cuid())
  tenantId                     String
  nome                         String
  finalidade                   String
  baseLegal                    BaseLegalLGPD
  categoriasDados              CategoriasDadosTratados[]
  titulares                    String
  compartilhamento             String?
  transferenciasInternacionais String?
  prazoRetencao                String
  medidasSeguranca             String
  dpoId                        String?
  criadoEm                     DateTime                  @default(now())
  atualizadoEm                 DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("registros_atividade_tratamento")
}

model RegistroProcessamentoDados {
  id            String       @id @default(cuid())
  tenantId      String
  titularId     String?
  tipoAcao      TipoAcaoLGPD
  entidade      String // nome da tabela/entidade
  entidadeId    String // ID do registro afetado
  dadosAfetados String // descrição dos campos
  usuarioId     String? // quem fez a ação
  justificativa String?
  criadoEm      DateTime     @default(now())

  titular TitularDados? @relation(fields: [titularId], references: [id], onDelete: SetNull)

  @@index([tenantId, titularId])
  @@index([tenantId, entidade, entidadeId])
  @@map("registros_processamento_dados")
}

// ── Incidentes LGPD ──────────────────────────────────────────────────────────

enum StatusIncidenteLGPD {
  detectado
  em_contencao
  notificado_anpd
  notificado_titular
  encerrado
}

enum GravidadeIncidente {
  baixa
  media
  alta
  critica
}

model IncidenteLGPD {
  id                     String              @id @default(cuid())
  tenantId               String
  titulo                 String
  descricao              String
  gravidade              GravidadeIncidente
  status                 StatusIncidenteLGPD @default(detectado)
  dataDeteccao           DateTime
  dataContencao          DateTime?
  dataNotificacaoAnpd    DateTime?
  dataNotificacaoTitular DateTime?
  prazoAnpd72h           DateTime
  numeroProtocoloAnpd    String?
  titularesAfetados      Int                 @default(0)
  dadosComprometidos     String
  medidasAdotadas        String?
  responsavelId          String?
  criadoEm               DateTime            @default(now())
  atualizadoEm           DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("incidentes_lgpd")
}

// ── DPO (Encarregado de Dados) ───────────────────────────────────────────────

model DPO {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  nome         String
  email        String
  telefone     String?
  empresa      String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("dpos")
}

// ── Reversibilidade ──────────────────────────────────────────────────────────

enum StatusReversao {
  planejamento
  em_execucao
  concluida
  cancelada
}

enum TipoItemReversao {
  migracao_dados
  devolucao_bens
  rescisao_contrato
  treinamento
  transferencia_documentos
  limpeza_ambiente
}

model PlanoReversao {
  id              String         @id @default(cuid())
  tenantId        String
  contratoId      String?
  titulo          String
  descricao       String?
  responsavel     String?
  dataInicio      DateTime?
  dataFimPrevista DateTime?
  dataFimReal     DateTime?
  status          StatusReversao @default(planejamento)
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  itens    ItemReversao[]
  contrato Contrato?      @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("planos_reversao")
}

model ItemReversao {
  id            String           @id @default(cuid())
  planoId       String
  tipo          TipoItemReversao
  descricao     String
  responsavel   String?
  dataPrevista  DateTime?
  dataConclusao DateTime?
  concluido     Boolean          @default(false)
  observacao    String?
  criadoEm      DateTime         @default(now())

  plano PlanoReversao @relation(fields: [planoId], references: [id], onDelete: Cascade)

  @@index([planoId])
  @@map("itens_reversao")
}

// ── Help Desk ────────────────────────────────────────────────────────────────

// ── SLA ──────────────────────────────────────────────────────────────────────

enum NivelSLA {
  critico
  alto
  medio
  baixo
}

enum StatusSLA {
  dentro_prazo
  em_risco
  vencido
}

model ConfiguracaoSLA {
  id           String   @id @default(cuid())
  tenantId     String
  nivel        NivelSLA
  prazoHoras   Int
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nivel])
  @@map("configuracoes_sla")
}

enum StatusTicket {
  aberto
  em_andamento
  aguardando_usuario
  resolvido
  fechado
}

enum PrioridadeTicket {
  baixa
  media
  alta
  critica
}

enum CategoriaTicket {
  duvida
  problema
  solicitacao
  reclamacao
  melhoria
}

model TicketSuporte {
  id             String           @id @default(cuid())
  tenantId       String
  titulo         String
  descricao      String
  categoria      CategoriaTicket
  prioridade     PrioridadeTicket @default(media)
  status         StatusTicket     @default(aberto)
  nivelSLA       NivelSLA?
  prazoResolucao DateTime?
  statusSLA      StatusSLA?
  solicitanteId  String
  responsavelId  String?
  dataResolucao  DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  mensagens MensagemTicket[]
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, solicitanteId])
  @@map("tickets_suporte")
}

model MensagemTicket {
  id        String   @id @default(cuid())
  ticketId  String
  autorId   String
  autorNome String
  mensagem  String
  interna   Boolean  @default(false) // visível apenas para equipe
  criadoEm  DateTime @default(now())

  ticket TicketSuporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("mensagens_ticket")
}

model ArtigoBaseConhecimento {
  id            String   @id @default(cuid())
  tenantId      String
  titulo        String
  slug          String   @unique
  conteudo      String
  categoria     String
  tags          String[]
  publicado     Boolean  @default(false)
  visualizacoes Int      @default(0)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, categoria])
  @@map("artigos_base_conhecimento")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 1 — NÚCLEO COMUM: CADASTROS ESTRUTURAIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Tipo de comissão administrativa.
enum TipoComissao {
  contratacao
  licitacao
  inventario_patrimonio
  inventario_almoxarifado
  recebimento
}

/// Função do membro dentro da comissão.
enum FuncaoMembroComissao {
  presidente
  membro
  suplente
  secretario
}

/// Centro de custo — unidade de controle e alocação de despesas.
model CentroCusto {
  id           String   @id @default(cuid())
  tenantId     String
  codigo       String
  nome         String
  descricao    String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant                          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setores                         Setor[]
  requisicoesMateriaisCentroCusto RequisicaoMaterial[]
  movimentacoesEstoque            MovimentacaoEstoque[]
  // Fase 4
  solicitacoesCompra              SolicitacaoCompra[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([tenantId, ativo])
  @@map("centros_custo")
}

/// Unidade gestora — unidade orçamentária e administrativa da entidade.
model UnidadeGestora {
  id           String   @id @default(cuid())
  tenantId     String
  codigo       String
  nome         String
  cnpj         String?
  gestor       String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setores Setor[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([tenantId, ativo])
  @@map("unidades_gestoras")
}

/// Setor — divisão interna da entidade, vinculada à unidade gestora e centro de custo.
model Setor {
  id               String   @id @default(cuid())
  tenantId         String
  codigo           String
  nome             String
  unidadeGestoraId String?
  centroCustoId    String?
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  tenant                    Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unidadeGestora            UnidadeGestora?               @relation(fields: [unidadeGestoraId], references: [id], onDelete: SetNull)
  centroCusto               CentroCusto?                  @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  requisicoesMateriaisSetor RequisicaoMaterial[]
  termosGuardaSetor         TermoGuardaResponsabilidade[]
  transferenciasDeSetor     TransferenciaPatrimonial[]    @relation("TransferenciaDeSetor")
  transferenciasParaSetor   TransferenciaPatrimonial[]    @relation("TransferenciaParaSetor")
  // Fase 4
  solicitacoesCompra        SolicitacaoCompra[]

  @@index([tenantId])
  @@index([tenantId, ativo])
  @@map("setores")
}

/// Comissão administrativa — contratação, licitação, inventário etc.
model Comissao {
  id             String       @id @default(cuid())
  tenantId       String
  tipo           TipoComissao
  nome           String
  decreto        String
  vigenciaInicio DateTime
  vigenciaFim    DateTime?
  ativo          Boolean      @default(true)
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membros     MembroComissao[]
  inventarios InventarioPatrimonial[]

  @@index([tenantId])
  @@index([tenantId, ativo])
  @@index([tenantId, tipo])
  @@map("comissoes")
}

/// Membro de comissão administrativa, vinculado opcionalmente a um usuário do sistema.
model MembroComissao {
  id           String                @id @default(cuid())
  comissaoId   String
  usuarioId    String?
  nomeCompleto String
  cargo        String
  funcao       FuncaoMembroComissao?
  criadoEm     DateTime              @default(now())

  comissao Comissao @relation(fields: [comissaoId], references: [id], onDelete: Cascade)

  @@index([comissaoId])
  @@map("membros_comissao")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WAVE 4A — HIERARQUIA DE MATERIAL (Portaria STN 448/2002)
// ═══════════════════════════════════════════════════════════════════════════════

/// Grupo de material — nível 1 da hierarquia STN 448/2002.
model GrupoMaterial {
  id           String   @id @default(cuid())
  tenantId     String
  codigo       String
  nome         String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes ClasseMaterial[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@map("grupos_material")
}

/// Classe de material — nível 2 da hierarquia STN 448/2002.
model ClasseMaterial {
  id           String   @id @default(cuid())
  grupoId      String
  codigo       String
  nome         String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  grupo      GrupoMaterial     @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  subclasses SubclasseMaterial[]

  @@unique([grupoId, codigo])
  @@index([grupoId])
  @@map("classes_material")
}

/// Subclasse de material — nível 3 da hierarquia STN 448/2002.
model SubclasseMaterial {
  id           String   @id @default(cuid())
  classeId     String
  codigo       String
  nome         String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  classe    ClasseMaterial @relation(fields: [classeId], references: [id], onDelete: Cascade)
  materiais Material[]

  @@unique([classeId, codigo])
  @@index([classeId])
  @@map("subclasses_material")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 2 — ALMOXARIFADO: MOVIMENTAÇÕES E REQUISIÇÕES
// ═══════════════════════════════════════════════════════════════════════════════

/// Tipo de movimentação de estoque — entradas e saídas.
enum TipoMovimentacao {
  entrada_nf
  entrada_ordem_compra
  entrada_doacao
  entrada_devolucao
  entrada_ajuste
  saida_requisicao
  saida_consumo_imediato
  saida_baixa
  saida_transferencia
  saida_ajuste
}

/// Status do ciclo de vida de uma requisição de material.
enum StatusRequisicao {
  rascunho
  enviada
  parcialmente_atendida
  atendida
  rejeitada
  cancelada
}

/// Registro histórico de movimentação no estoque — cada entrada ou saída gera um registro.
model MovimentacaoEstoque {
  id                      String           @id @default(cuid())
  tenantId                String
  almoxarifadoId          String
  materialId              String
  tipo                    TipoMovimentacao
  quantidade              Decimal          @db.Decimal(18, 4)
  valorUnitario           Decimal          @db.Decimal(18, 4)
  valorTotal              Decimal          @db.Decimal(18, 4)
  precoMedioAposMovimento Decimal          @db.Decimal(18, 4)
  notaFiscal              String?
  ordemCompra             String?
  empenhoId               String?
  requisicaoId            String?
  transferenciaPairId     String?
  responsavelId           String?
  centroCustoId           String?
  observacao              String?
  dataMovimento           DateTime
  criadoEm                DateTime         @default(now())

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  almoxarifado         Almoxarifado          @relation(fields: [almoxarifadoId], references: [id])
  material             Material              @relation(fields: [materialId], references: [id])
  empenho              Empenho?              @relation(fields: [empenhoId], references: [id], onDelete: SetNull)
  requisicao           RequisicaoMaterial?   @relation(fields: [requisicaoId], references: [id], onDelete: SetNull)
  centroCusto          CentroCusto?          @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  transferenciaPar     MovimentacaoEstoque?  @relation("TransferenciaPar", fields: [transferenciaPairId], references: [id])
  transferenciasFilhas MovimentacaoEstoque[] @relation("TransferenciaPar")

  @@index([tenantId, almoxarifadoId, materialId])
  @@index([tenantId, dataMovimento(sort: Desc)])
  @@index([tenantId, tipo])
  @@map("movimentacoes_estoque")
}

/// Requisição de material ao almoxarifado — ciclo de solicitação e atendimento.
model RequisicaoMaterial {
  id                       String           @id @default(cuid())
  tenantId                 String
  numero                   String
  ano                      Int
  almoxarifadoId           String
  setorRequisitanteId      String?
  centroCustoId            String?
  solicitanteId            String
  responsavelAtendimentoId String?
  status                   StatusRequisicao @default(rascunho)
  justificativa            String
  criadoEm                 DateTime         @default(now())
  atualizadoEm             DateTime         @updatedAt
  atendidaEm               DateTime?

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  almoxarifado      Almoxarifado             @relation(fields: [almoxarifadoId], references: [id])
  setorRequisitante Setor?                   @relation(fields: [setorRequisitanteId], references: [id], onDelete: SetNull)
  centroCusto       CentroCusto?             @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  itens             ItemRequisicaoMaterial[]
  movimentacoes     MovimentacaoEstoque[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId, status])
  @@index([tenantId, ano])
  @@map("requisicoes_materiais")
}

/// Item de uma requisição de material — detalhe por material solicitado.
model ItemRequisicaoMaterial {
  id                   String  @id @default(cuid())
  requisicaoId         String
  materialId           String
  quantidadeSolicitada Decimal @db.Decimal(18, 4)
  quantidadeAtendida   Decimal @default(0) @db.Decimal(18, 4)
  observacao           String?

  requisicao RequisicaoMaterial @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)
  material   Material           @relation(fields: [materialId], references: [id])

  @@index([requisicaoId])
  @@map("itens_requisicao_material")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 3 — PATRIMÔNIO: TERMOS E TRANSFERÊNCIAS
// ═══════════════════════════════════════════════════════════════════════════════

/// Status do termo de guarda e responsabilidade.
enum StatusTermo {
  emitido
  aceito
  substituido
  cancelado
}

/// Termo de guarda e responsabilidade — vincula bens patrimoniais a um responsável.
model TermoGuardaResponsabilidade {
  id                  String      @id @default(cuid())
  tenantId            String
  numero              String
  ano                 Int
  responsavelId       String
  setorId             String?
  dataEmissao         DateTime
  dataAceite          DateTime?
  status              StatusTermo @default(emitido)
  arquivoDocumentoUrl String?
  criadoEm            DateTime    @default(now())
  atualizadoEm        DateTime    @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setor  Setor?     @relation(fields: [setorId], references: [id], onDelete: SetNull)
  bens   BemTermo[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, responsavelId])
  @@map("termos_guarda_responsabilidade")
}

/// Tabela de junção entre TermoGuardaResponsabilidade e BemPatrimonial.
model BemTermo {
  id               String @id @default(cuid())
  termoId          String
  bemPatrimonialId String

  termo          TermoGuardaResponsabilidade @relation(fields: [termoId], references: [id], onDelete: Cascade)
  bemPatrimonial BemPatrimonial              @relation(fields: [bemPatrimonialId], references: [id], onDelete: Cascade)

  @@unique([termoId, bemPatrimonialId])
  @@index([termoId])
  @@index([bemPatrimonialId])
  @@map("bens_termos")
}

/// Registro de transferência patrimonial — mudança de responsável, setor ou localização de bens.
model TransferenciaPatrimonial {
  id                         String   @id @default(cuid())
  tenantId                   String
  bemPatrimonialId           String
  dataTransferencia          DateTime
  deResponsavelId            String?
  paraResponsavelId          String?
  deSetorId                  String?
  paraSetorId                String?
  deLocalizacao              String?
  paraLocalizacao            String?
  motivo                     String
  documentoAutorizadorNumero String?
  criadoEm                   DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bemPatrimonial BemPatrimonial @relation(fields: [bemPatrimonialId], references: [id])
  deSetor        Setor?         @relation("TransferenciaDeSetor", fields: [deSetorId], references: [id], onDelete: SetNull)
  paraSetor      Setor?         @relation("TransferenciaParaSetor", fields: [paraSetorId], references: [id], onDelete: SetNull)

  @@index([tenantId, bemPatrimonialId])
  @@index([tenantId, dataTransferencia(sort: Desc)])
  @@map("transferencias_patrimoniais")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4 — FORNECEDORES: SANÇÕES ADMINISTRATIVAS
// ═══════════════════════════════════════════════════════════════════════════════

/// Tipo de sanção administrativa aplicável a fornecedor.
enum TipoSancao {
  advertencia
  multa
  suspensao_temporaria
  declaracao_inidoneidade
  impedimento_licitar
}

/// Sanção administrativa aplicada a fornecedor — art. 156 Lei 14.133/2021.
model SancaoFornecedor {
  id                          String     @id @default(cuid())
  tenantId                    String
  fornecedorId                String
  tipo                        TipoSancao
  processoSancionatorioNumero String?
  fundamentoLegal             String
  dataInicio                  DateTime
  dataFim                     DateTime?
  descricao                   String
  ativa                       Boolean    @default(true)
  criadoEm                    DateTime   @default(now())
  atualizadoEm                DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  @@index([tenantId, fornecedorId])
  @@index([tenantId, ativa])
  @@index([tenantId, dataFim])
  @@map("sancoes_fornecedor")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4a — COMPRAS / PCA
// ═══════════════════════════════════════════════════════════════════════════════

enum StatusPCA {
  rascunho
  em_elaboracao
  aprovado
  publicado
  encerrado
}

enum StatusSolicitacaoCompra {
  rascunho
  pre_autorizada
  autorizada
  negada
  convertida_processo
  cancelada
}

/// Plano de Contratações Anual — instrumento de planejamento de compras (Lei 14.133/2021 art. 12).
model PCA {
  id             String    @id @default(cuid())
  tenantId       String
  ano            Int
  titulo         String
  status         StatusPCA @default(rascunho)
  dataAprovacao  DateTime?
  dataPublicacao DateTime?
  observacoes    String?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itens  ItemPCA[]

  @@unique([tenantId, ano])
  @@index([tenantId, status])
  @@map("pcas")
}

/// Item do PCA — cada contratação planejada para o exercício.
model ItemPCA {
  id                    String   @id @default(cuid())
  pcaId                 String
  materialId            String?
  descricao             String
  quantidadeEstimada    Decimal  @db.Decimal(18, 4)
  valorUnitarioEstimado Decimal  @db.Decimal(18, 2)
  valorTotalEstimado    Decimal  @db.Decimal(18, 2)
  mesPretendido         Int
  categoria             String
  justificativa         String?
  criadoEm              DateTime @default(now())

  pca      PCA       @relation(fields: [pcaId], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([pcaId])
  @@map("itens_pca")
}

/// Solicitação de compra — pedido interno originado em setor requisitante.
model SolicitacaoCompra {
  id                    String                  @id @default(cuid())
  tenantId              String
  numero                String
  ano                   Int
  solicitanteId         String
  centroCustoId         String?
  setorId               String?
  justificativa         String
  status                StatusSolicitacaoCompra @default(rascunho)
  preAutorizadorId      String?
  autorizadorId         String?
  processoLicitatorioId String?
  motivoRecusa          String?
  criadoEm              DateTime                @default(now())
  atualizadoEm          DateTime                @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  centroCusto         CentroCusto?            @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  setor               Setor?                  @relation(fields: [setorId], references: [id], onDelete: SetNull)
  processoLicitatorio ProcessoLicitatorio?    @relation(fields: [processoLicitatorioId], references: [id], onDelete: SetNull)
  itens               ItemSolicitacaoCompra[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId, status])
  @@index([tenantId, solicitanteId])
  @@map("solicitacoes_compra")
}

/// Item de solicitação de compra.
model ItemSolicitacaoCompra {
  id                    String   @id @default(cuid())
  solicitacaoId         String
  materialId            String?
  descricao             String
  quantidade            Decimal  @db.Decimal(18, 4)
  valorUnitarioEstimado Decimal  @db.Decimal(18, 2)
  valorTotalEstimado    Decimal  @db.Decimal(18, 2)
  unidadeMedida         String?
  criadoEm              DateTime @default(now())

  solicitacao SolicitacaoCompra @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  material    Material?         @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([solicitacaoId])
  @@map("itens_solicitacao_compra")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4b — PESQUISA DE PREÇOS, PREGÃO, ATAS, IMPUGNAÇÕES
// ═══════════════════════════════════════════════════════════════════════════════

enum StatusPesquisaPreco {
  aberta
  encerrada
  cancelada
}

enum StatusCotacao {
  rascunho
  enviada
  respondida
  expirada
  recusada
}

enum StatusEdital {
  rascunho
  publicado
  substituido
}

enum TipoAta {
  registro_precos
  sessao_pregao
  abertura_envelope
  julgamento_propostas
  adjudicacao
  homologacao
  outro
}

enum StatusImpugnacao {
  recebida
  em_analise
  deferida
  indeferida
  prejudicada
}

enum StatusRecurso {
  recebido
  em_contrarrazoes
  em_analise
  deferido
  indeferido
  prejudicado
}

enum TipoPregao {
  eletronico
  presencial
}

enum StatusSessaoPregao {
  agendada
  aberta
  em_lance
  em_negociacao
  suspensa
  encerrada
  fracassada
  deserta
}

enum TipoLance {
  lance
  lance_intermediario
  negociacao
}

enum StatusHabilitacao {
  pendente
  habilitado
  inabilitado
  em_analise
}

/// Pesquisa de preços — instrumento para estimativa de valor antes do processo licitatório.
model PesquisaPreco {
  id           String              @id @default(cuid())
  tenantId     String
  numero       String
  ano          Int
  objeto       String
  dataInicio   DateTime
  dataFim      DateTime?
  status       StatusPesquisaPreco @default(aberta)
  processoId   String?
  criadoPorId  String
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo ProcessoLicitatorio? @relation(fields: [processoId], references: [id], onDelete: SetNull)
  itens    ItemPesquisaPreco[]
  cotacoes Cotacao[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId, status])
  @@map("pesquisas_preco")
}

/// Item de pesquisa de preço.
model ItemPesquisaPreco {
  id            String  @id @default(cuid())
  pesquisaId    String
  materialId    String?
  descricao     String
  quantidade    Decimal @db.Decimal(18, 4)
  unidadeMedida String?

  pesquisa     PesquisaPreco @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  material     Material?     @relation(fields: [materialId], references: [id], onDelete: SetNull)
  itensCotacao ItemCotacao[]

  @@index([pesquisaId])
  @@map("itens_pesquisa_preco")
}

/// Cotação — proposta de um fornecedor vinculada à pesquisa de preços.
model Cotacao {
  id                String        @id @default(cuid())
  pesquisaId        String
  fornecedorId      String
  tokenAcessoOnline String?       @unique
  dataEnvio         DateTime?
  dataResposta      DateTime?
  valorTotal        Decimal?      @db.Decimal(18, 2)
  validadeProposta  DateTime?
  observacao        String?
  status            StatusCotacao @default(rascunho)

  pesquisa   PesquisaPreco @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor    @relation(fields: [fornecedorId], references: [id])
  itens      ItemCotacao[]

  @@unique([pesquisaId, fornecedorId])
  @@map("cotacoes")
}

/// Item da cotação — resposta do fornecedor por item da pesquisa.
model ItemCotacao {
  id               String  @id @default(cuid())
  cotacaoId        String
  itemPesquisaId   String
  valorUnitario    Decimal @db.Decimal(18, 2)
  marca            String?
  prazoEntregaDias Int?
  observacao       String?

  cotacao      Cotacao           @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  itemPesquisa ItemPesquisaPreco @relation(fields: [itemPesquisaId], references: [id])

  @@index([cotacaoId])
  @@map("itens_cotacao")
}

/// Edital — documento base do processo licitatório com versionamento.
model Edital {
  id               String       @id @default(cuid())
  tenantId         String
  processoId       String
  versao           Int          @default(1)
  titulo           String
  conteudoHtml     String?
  arquivoUrl       String?
  status           StatusEdital @default(rascunho)
  publicadoEm      DateTime?
  publicadoPorId   String?
  substituidoPorId String?

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo       ProcessoLicitatorio @relation(fields: [processoId], references: [id], onDelete: Cascade)
  substituidoPor Edital?             @relation("EditalSubstituicao", fields: [substituidoPorId], references: [id])
  substitui      Edital[]            @relation("EditalSubstituicao")

  @@index([tenantId, processoId, versao])
  @@map("editais")
}

/// Ata — lavrada em sessões, licitações, ARP e outros atos formais.
model Ata {
  id             String    @id @default(cuid())
  tenantId       String
  processoId     String?
  tipo           TipoAta
  numero         String
  ano            Int
  conteudoHtml   String?
  arquivoUrl     String?
  dataLavratura  DateTime
  dataAssinatura DateTime?
  criadoPorId    String
  validadeInicio DateTime?
  validadeFim    DateTime?

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo ProcessoLicitatorio?   @relation(fields: [processoId], references: [id], onDelete: SetNull)
  itensARP ItemAtaRegistroPreco[]

  @@index([tenantId, numero, ano, tipo])
  @@map("atas")
}

/// Item de Ata de Registro de Preços — saldo gerenciado durante a vigência da ARP.
model ItemAtaRegistroPreco {
  id                      String   @id @default(cuid())
  ataId                   String
  materialId              String?
  descricao               String
  quantidadeRegistrada    Decimal  @db.Decimal(18, 4)
  saldoDisponivel         Decimal  @db.Decimal(18, 4)
  valorUnitarioRegistrado Decimal  @db.Decimal(18, 2)
  fornecedorId            String
  criadoEm                DateTime @default(now())

  ata        Ata        @relation(fields: [ataId], references: [id], onDelete: Cascade)
  material   Material?  @relation(fields: [materialId], references: [id], onDelete: SetNull)
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])

  @@index([ataId])
  @@map("itens_ata_registro_preco")
}

/// Impugnação ao edital — contestação de licitante ou cidadão (art. 164 Lei 14.133/2021).
model Impugnacao {
  id                      String           @id @default(cuid())
  tenantId                String
  processoId              String
  impugnanteNome          String
  impugnanteIdentificador String
  impugnanteEmail         String?
  dataImpugnacao          DateTime
  conteudo                String
  fundamentoLegal         String?
  status                  StatusImpugnacao @default(recebida)
  parecerJulgamento       String?
  julgadoPorId            String?
  dataJulgamento          DateTime?
  criadoEm                DateTime         @default(now())

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo ProcessoLicitatorio @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([tenantId, processoId])
  @@map("impugnacoes")
}

/// Recurso administrativo — interposto por licitante após decisão (art. 165 Lei 14.133/2021).
model Recurso {
  id                      String        @id @default(cuid())
  tenantId                String
  processoId              String
  recorrenteFornecedorId  String?
  recorrenteIdentificador String
  dataInterposicao        DateTime
  dataLimitContrarrazoes  DateTime?
  conteudo                String
  status                  StatusRecurso @default(recebido)
  contrarrazoes           String?
  parecerJulgamento       String?
  dataJulgamento          DateTime?
  julgadoPorId            String?

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo   ProcessoLicitatorio @relation(fields: [processoId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor?         @relation(fields: [recorrenteFornecedorId], references: [id], onDelete: SetNull)

  @@index([tenantId, processoId])
  @@map("recursos")
}

/// Sessão de pregão — controla o andamento da disputa eletrônica ou presencial.
model SessaoPregao {
  id           String             @id @default(cuid())
  tenantId     String
  processoId   String
  dataAbertura DateTime
  tipo         TipoPregao
  status       StatusSessaoPregao @default(agendada)
  pregoeiroId  String
  atasInternas Json?
  criadoEm     DateTime           @default(now())
  encerradoEm  DateTime?

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo     ProcessoLicitatorio     @relation(fields: [processoId], references: [id], onDelete: Cascade)
  lances       Lance[]
  habilitacoes HabilitacaoFornecedor[]

  @@index([tenantId, processoId])
  @@map("sessoes_pregao")
}

/// Lance em sessão de pregão — histórico imutável de lances por item.
model Lance {
  id              String    @id @default(cuid())
  sessaoId        String
  itemLicitacaoId String
  fornecedorId    String
  valor           Decimal   @db.Decimal(18, 2)
  ordem           Int
  tipo            TipoLance @default(lance)
  criadoEm        DateTime  @default(now())

  sessao        SessaoPregao  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  itemLicitacao ItemLicitacao @relation(fields: [itemLicitacaoId], references: [id])
  fornecedor    Fornecedor    @relation(fields: [fornecedorId], references: [id])

  @@index([sessaoId, itemLicitacaoId, ordem])
  @@map("lances")
}

/// Habilitação de fornecedor em sessão de pregão.
model HabilitacaoFornecedor {
  id             String            @id @default(cuid())
  sessaoId       String
  fornecedorId   String
  status         StatusHabilitacao @default(pendente)
  motivo         String?
  documentos     Json?
  julgadoPorId   String?
  dataJulgamento DateTime?

  sessao     SessaoPregao @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor   @relation(fields: [fornecedorId], references: [id])

  @@unique([sessaoId, fornecedorId])
  @@map("habilitacoes_fornecedor")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4c bis — GARANTIAS, CLÁUSULAS-MODELO, CRONOGRAMA, RESTOS A PAGAR
// ═══════════════════════════════════════════════════════════════════════════════

enum TipoGarantia {
  caucao_dinheiro
  seguro_garantia
  fianca_bancaria
  titulos_divida_publica
}

enum SituacaoGarantia {
  vigente
  liberada
  executada
  vencida
  substituida
}

enum CategoriaClausula {
  geral
  sancao
  reajuste
  garantia
  prazo
  pagamento
  rescisao
  alteracao
  fiscalizacao
}

enum SituacaoRestoPagar {
  processado
  nao_processado
  prescrito
  cancelado
  pago
}

/// Garantia contratual — caução, seguro ou fiança vinculada a contrato (art. 96 Lei 14.133/2021).
model Garantia {
  id              String           @id @default(cuid())
  tenantId        String
  contratoId      String
  tipo            TipoGarantia
  valor           Decimal          @db.Decimal(18, 2)
  dataInicio      DateTime
  dataFim         DateTime
  situacao        SituacaoGarantia @default(vigente)
  beneficiario    String?
  numeroDocumento String?
  arquivoUrl      String?
  observacao      String?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([tenantId, contratoId])
  @@index([tenantId, situacao])
  @@index([tenantId, dataFim])
  @@map("garantias")
}

/// Cláusula-modelo — biblioteca de cláusulas reutilizáveis em contratos e editais.
model ClausulaModelo {
  id           String            @id @default(cuid())
  tenantId     String
  codigo       String
  titulo       String
  conteudoMd   String
  categoria    CategoriaClausula
  ordem        Int               @default(0)
  ativo        Boolean           @default(true)
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, codigo])
  @@index([tenantId, categoria, ordem])
  @@map("clausulas_modelo")
}

/// Cronograma físico-financeiro — parcelas previstas e realizadas do contrato.
model CronogramaFisicoFinanceiro {
  id                   String    @id @default(cuid())
  tenantId             String
  contratoId           String
  parcela              Int
  descricao            String
  dataPrevista         DateTime
  valorPrevisto        Decimal   @db.Decimal(18, 2)
  dataRealizada        DateTime?
  valorRealizado       Decimal?  @db.Decimal(18, 2)
  percentualFisico     Decimal?  @db.Decimal(5, 2)
  percentualFinanceiro Decimal?  @db.Decimal(5, 2)
  observacao           String?
  criadoEm             DateTime  @default(now())
  atualizadoEm         DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, parcela])
  @@map("cronogramas_fisico_financeiros")
}

/// Resto a pagar — empenho não liquidado/pago até o encerramento do exercício.
model RestoPagar {
  id             String             @id @default(cuid())
  tenantId       String
  exercicio      Int
  empenhoId      String             @unique
  valorInscrito  Decimal            @db.Decimal(18, 2)
  valorPago      Decimal            @default(0) @db.Decimal(18, 2)
  valorCancelado Decimal            @default(0) @db.Decimal(18, 2)
  saldo          Decimal            @db.Decimal(18, 2)
  situacao       SituacaoRestoPagar @default(nao_processado)
  dataInscricao  DateTime
  dataPrescricao DateTime?
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  empenho Empenho @relation(fields: [empenhoId], references: [id])

  @@index([tenantId, exercicio])
  @@map("restos_pagar")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 4d — CONVÊNIOS + FISCALIZAÇÃO DE CONTRATOS
// ═══════════════════════════════════════════════════════════════════════════════

enum TipoConvenio {
  concedido
  recebido
  termo_cooperacao
  termo_fomento
}

enum StatusConvenio {
  ativo
  encerrado
  rescindido
  prestacao_pendente
  prestacao_aprovada
  prestacao_rejeitada
}

enum StatusParcelaConvenio {
  prevista
  liberada
  prestacao_pendente
  prestacao_aprovada
  prestacao_rejeitada
}

enum TipoFiscal {
  fiscal_titular
  fiscal_substituto
  gestor
}

enum TipoOcorrencia {
  medicao
  reclamacao
  nao_conformidade
  elogio
  alerta
  infracao
  atestado_recebimento
}

enum GravidadeOcorrencia {
  baixa
  media
  alta
  critica
}

enum StatusOcorrencia {
  aberta
  em_tratamento
  resolvida
  escalada
  arquivada
}

enum StatusMedicao {
  rascunho
  aprovada
  paga
  glosada
}

/// Convênio — instrumento de cooperação entre entes públicos e privados (Lei 13.019/2014).
model Convenio {
  id                        String         @id @default(cuid())
  tenantId                  String
  numero                    String
  ano                       Int
  tipo                      TipoConvenio
  concedenteNome            String
  concedenteIdentificador   String
  beneficiarioNome          String
  beneficiarioIdentificador String
  objeto                    String
  valorTotal                Decimal        @db.Decimal(18, 2)
  valorRepasse              Decimal        @db.Decimal(18, 2)
  valorContrapartida        Decimal        @db.Decimal(18, 2)
  dataAssinatura            DateTime
  vigenciaInicio            DateTime
  vigenciaFim               DateTime
  status                    StatusConvenio @default(ativo)
  gestorId                  String?
  processoId                String?
  arquivoUrl                String?
  criadoEm                  DateTime       @default(now())
  atualizadoEm              DateTime       @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processo ProcessoLicitatorio? @relation(fields: [processoId], references: [id], onDelete: SetNull)
  parcelas ParcelaConvenio[]

  @@unique([tenantId, numero, ano])
  @@index([tenantId, status])
  @@index([tenantId, vigenciaFim])
  @@map("convenios")
}

/// Parcela de convênio — liberação programada de recursos com prestação de contas.
model ParcelaConvenio {
  id                  String                @id @default(cuid())
  convenioId          String
  numero              Int
  dataPrevista        DateTime
  valor               Decimal               @db.Decimal(18, 2)
  dataLiberacao       DateTime?
  dataPrestacaoContas DateTime?
  status              StatusParcelaConvenio @default(prevista)
  observacao          String?
  criadoEm            DateTime              @default(now())

  convenio Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  @@unique([convenioId, numero])
  @@map("parcelas_convenio")
}

/// Designação de fiscal de contrato — obrigatória pela Lei 14.133/2021 art. 117.
model FiscalizacaoContrato {
  id               String     @id @default(cuid())
  tenantId         String
  contratoId       String
  fiscalId         String
  tipo             TipoFiscal
  dataDesignacao   DateTime
  dataEncerramento DateTime?
  decretoPortaria  String?
  observacao       String?
  criadoEm         DateTime   @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([tenantId, contratoId])
  @@index([fiscalId])
  @@map("fiscalizacoes_contrato")
}

/// Ocorrência de fiscalização — registro de fatos durante a execução contratual.
model OcorrenciaFiscalizacao {
  id             String              @id @default(cuid())
  tenantId       String
  contratoId     String
  fiscalId       String
  dataOcorrencia DateTime
  tipo           TipoOcorrencia
  gravidade      GravidadeOcorrencia
  descricao      String
  evidenciaUrl   String?
  tratamento     String?
  dataTratamento DateTime?
  status         StatusOcorrencia    @default(aberta)
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([tenantId, contratoId])
  @@index([tenantId, status])
  @@index([tenantId, dataOcorrencia])
  @@map("ocorrencias_fiscalizacao")
}

/// Medição de contrato — ateste de execução física e financeira por período.
model MedicaoContrato {
  id                  String        @id @default(cuid())
  tenantId            String
  contratoId          String
  fiscalId            String
  numero              Int
  periodoInicio       DateTime
  periodoFim          DateTime
  valorMedido         Decimal       @db.Decimal(18, 2)
  percentualExecutado Decimal?      @db.Decimal(5, 2)
  status              StatusMedicao @default(rascunho)
  observacao          String?
  criadoEm            DateTime      @default(now())
  atualizadoEm        DateTime      @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, numero])
  @@index([tenantId, contratoId])
  @@map("medicoes_contrato")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WAVE 6A — INVENTÁRIO PATRIMONIAL FORMAL, e-SIC LAI, RECEITAS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Inventário Patrimonial ──────────────────────────────────────────────────

/// Status do processo de inventário patrimonial formal.
enum StatusInventario {
  aberto
  em_contagem
  em_conciliacao
  encerrado
  cancelado
}

/// Resultado da conferência de um item no inventário.
enum ResultadoItemInventario {
  confirmado
  nao_localizado
  divergencia_valor
  excedente
}

/// Inventário patrimonial formal — processo anual obrigatório (Lei 4.320/1964 art. 94).
model InventarioPatrimonial {
  id               String           @id @default(cuid())
  tenantId         String
  exercicio        Int
  numero           String
  dataAbertura     DateTime
  dataEncerramento DateTime?
  status           StatusInventario @default(aberto)
  comissaoId       String?
  observacoes      String?
  criadoPorId      String
  criadoEm         DateTime         @default(now())
  atualizadoEm     DateTime         @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  comissao Comissao?             @relation(fields: [comissaoId], references: [id], onDelete: SetNull)
  itens    ItemInventario[]

  @@unique([tenantId, numero, exercicio])
  @@index([tenantId, status])
  @@map("inventarios_patrimoniais")
}

/// Item de inventário — resultado da conferência de um bem patrimonial.
model ItemInventario {
  id                    String                   @id @default(cuid())
  inventarioId          String
  bemPatrimonialId      String
  localizacaoEsperada   String?
  localizacaoEncontrada String?
  valorContabil         Decimal                  @db.Decimal(18, 2)
  resultado             ResultadoItemInventario?
  observacoes           String?
  conferidoPorId        String?
  conferidoEm           DateTime?

  inventario     InventarioPatrimonial @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  bemPatrimonial BemPatrimonial        @relation(fields: [bemPatrimonialId], references: [id])

  @@unique([inventarioId, bemPatrimonialId])
  @@index([inventarioId])
  @@map("itens_inventario")
}

// ─── e-SIC — Sistema Eletrônico de Informações ao Cidadão ───────────────────

/// Status da solicitação e-SIC conforme LAI 12.527/2011.
enum StatusSolicitacaoSIC {
  recebida
  em_tramitacao
  respondida
  prorrogada
  negada
  encaminhada
}

/// Solicitação e-SIC — pedido de acesso à informação via LAI 12.527/2011.
model SolicitacaoESIC {
  id               String               @id @default(cuid())
  tenantId         String
  protocolo        String               @unique
  solicitanteNome  String
  solicitanteEmail String
  solicitanteCpf   String?
  descricao        String
  status           StatusSolicitacaoSIC @default(recebida)
  resposta         String?
  dataResposta     DateTime?
  prazoLegal       DateTime
  prorrogadoAte    DateTime?
  responsavelId    String?
  criadoEm         DateTime             @default(now())
  atualizadoEm     DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([protocolo])
  @@map("solicitacoes_esic")
}

// ─── Receitas ────────────────────────────────────────────────────────────────

/// Tipo de receita conforme classificação orçamentária pública.
enum TipoReceita {
  tributaria
  patrimonial
  de_servicos
  transferencias_correntes
  operacoes_credito
  outras
}

/// Status da receita no ciclo orçamentário.
enum StatusReceita {
  prevista
  lancada
  arrecadada
  cancelada
}

/// Receita pública — previsão e arrecadação mensal por natureza e fonte.
model Receita {
  id              String        @id @default(cuid())
  tenantId        String
  exercicio       Int
  mes             Int
  tipo            TipoReceita
  natureza        String
  descricao       String
  valorPrevisto   Decimal       @db.Decimal(18, 2)
  valorArrecadado Decimal?      @db.Decimal(18, 2)
  status          StatusReceita @default(prevista)
  fonte           String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, exercicio, mes])
  @@map("receitas")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WAVE 6D — Agentes de Contratação (Lei 14.133/2021, Art. 8°)
// ═══════════════════════════════════════════════════════════════════════════════

/// Agente de contratação designado por portaria (Lei 14.133/2021, Art. 8°).
model AgenteContratacao {
  id             String    @id @default(cuid())
  tenantId       String
  usuarioId      String?
  nome           String
  matricula      String?
  portaria       String?
  vigenciaInicio DateTime
  vigenciaFim    DateTime?
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ativo])
  @@map("agentes_contratacao")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FASE 11 — Fundação v0.5: LogAcesso (B3), Notificações (B8)
// ═══════════════════════════════════════════════════════════════════════════════

/// Evento de acesso registrado em `LogAcesso` (REQ-NF-013).
enum EventoAcesso {
  LOGIN_SUCESSO
  LOGIN_FALHA
  LOGOUT
  REFRESH_TOKEN
  TOTP_OK
  TOTP_FALHA
  SENHA_RECUPERACAO_SOLICITADA
  SENHA_RECUPERACAO_USADA
}

/// Categoria de notificação para a central persistente (REQ-NF-072, REQ-ALEM-023).
enum CategoriaNotificacao {
  CHAMADO
  CONTRATO
  RELATORIO
  DOCUMENTO
  AUDITORIA
  SISTEMA
}

/// Trilha dedicada de login/logout/refresh — REQ-NF-013 (B3).
/// Independente de `Auditoria`: trilha de identidade não passa por hash chain
/// (auditar a trilha gera loop). `usuarioId` nullable porque login falho pode
/// não ter usuário resolvido.
model LogAcesso {
  id        String       @id @default(cuid())
  tenantId  String
  usuarioId String?
  evento    EventoAcesso
  ip        String?
  userAgent String?
  sistema   String?
  ocorreuEm DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ocorreuEm(sort: Desc)])
  @@index([tenantId, usuarioId])
  @@index([tenantId, evento])
  @@map("log_acesso")
}

/// Central persistente de notificações in-app — sino na topbar (B8).
/// Polling a cada 30s no client; sem WebSocket no PoC.
model Notificacao {
  id        String               @id @default(cuid())
  tenantId  String
  usuarioId String
  categoria CategoriaNotificacao
  titulo    String
  corpo     String
  link      String?
  lida      Boolean              @default(false)
  lidaEm    DateTime?
  criadoEm  DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, usuarioId, lida])
  @@index([tenantId, criadoEm(sort: Desc)])
  @@map("notificacoes")
}

/// Opt-in/opt-out por categoria de notificação (NOTIF-04).
model PreferenciaNotificacao {
  id         String               @id @default(cuid())
  tenantId   String
  usuarioId  String
  categoria  CategoriaNotificacao
  habilitada Boolean              @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usuarioId, categoria])
  @@map("preferencias_notificacao")
}
