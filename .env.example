DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
AUTH_SECRET=substitua_por_hash_32_bytes
NEXTAUTH_URL=https://seu-dominio.com

# ── S3 / Wasabi ─────────────────────────────────────────────────────────────
# Use uma das duas convenções (WAS_* tem prioridade sobre S3_*):
#
# Opção A — Wasabi-style (recomendado para Wasabi)
# WAS_ACCESS_KEY_ID=Z67TBUTXOS16EDYEMVSE
# WAS_SECRET_ACCESS_KEY=sua-secret-key
# WAS_URL=s3.us-central-1.wasabisys.com
# WAS_DEFAULT_REGION=us-central-1
# WAS_BUCKET=arquivosc.devnx.com.br
# WAS_ENDPOINT=/civitas/uploads
#
# Opção B — Genérica (compatível com qualquer S3)
S3_ENDPOINT=https://s3.wasabisys.com
S3_REGION=us-east-1
S3_BUCKET=seu-bucket
S3_ACCESS_KEY=sua-access-key
S3_SECRET_KEY=sua-secret-key
S3_FORCE_PATH_STYLE=false

OPENAI_API_KEY=sk-...
CRON_SECRET=secret_para_cron

# ── Sentry ───────────────────────────────────────────────────────────────────
# DSN público do projeto Sentry (deixe em branco para desabilitar o tracking)
NEXT_PUBLIC_SENTRY_DSN=
