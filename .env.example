# ----------------------------------------------------------------------
# Civitas Gov — variáveis de ambiente
# Auth → .env.local · Banco de dados → .env (lido pelo Next.js e pelo Prisma).
# ----------------------------------------------------------------------

# Banco de dados PostgreSQL (container Docker — ver docker-compose.yml).
# Colocar em .env (o Prisma CLI lê .env; o Next.js lê .env e .env.local).
DATABASE_URL="postgresql://civitas:civitas_dev@localhost:5442/civitas_gov"

# Armazenamento S3-compatível (MinIO local em dev — porta 9000 / console 9001).
# Em produção, apontar para AWS S3: omitir S3_ENDPOINT e S3_FORCE_PATH_STYLE.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="civitas-dev"
S3_ACCESS_KEY="civitas"
S3_SECRET_KEY="civitas_dev_secret"
S3_FORCE_PATH_STYLE="true"

# Segredo usado para assinar os tokens de sessão (Auth.js / NextAuth v5).
# Gere um novo com:  openssl rand -base64 32
AUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio"

# URL base da aplicação (necessária em produção).
# AUTH_URL="https://civitas.example.gov.br"

# Confia no host em ambientes de proxy/preview.
AUTH_TRUST_HOST=true
