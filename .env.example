# ----------------------------------------------------------------------
# Civitas Gov — variáveis de ambiente
# Copie este arquivo para .env.local e ajuste os valores.
# ----------------------------------------------------------------------

# Segredo usado para assinar os tokens de sessão (Auth.js / NextAuth v5).
# Gere um novo com:  openssl rand -base64 32
AUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio"

# URL base da aplicação (necessária em produção).
# AUTH_URL="https://civitas.example.gov.br"

# Confia no host em ambientes de proxy/preview.
AUTH_TRUST_HOST=true
